# ==============================
# Kepler Backend - Environment Variables
# ==============================
# Copy this file to .env and fill in the values.
# Do NOT commit the .env file to version control.

# ---- Server ----
PORT=8000

# ---- MongoDB ----
# SERVER is the MongoDB Atlas connection string (user:password@cluster-url)
SERVER=your_mongodb_user:your_password@your_cluster.mongodb.net
DATABASE=your_database_name

# ---- PostgreSQL ----
POSTGRES_URL=postgresql://user:password@host:5432/database_name

# ---- Redis ----
REDIS_URL=redis://default:password@host:port

# ---- JWT Authentication ----
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret

# ---- Google OAuth (Passport) ----
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# ---- Gmail API (OAuth2 for sending emails) ----
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_gmail_app_password
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_oauth_refresh_token
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground

# ---- Brevo / SendinBlue (Fallback Email Service) ----
BREVO_API_KEY=your_brevo_api_key

# ---- Razorpay (Payment Gateway) ----
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

# ---- Cloudinary (Image / File Storage) ----
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
